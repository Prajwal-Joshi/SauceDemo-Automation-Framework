<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="SauceDemo Full Automation Suite">

    <!-- Global Parameters -->
    <parameter name="browser" value="chrome"/>

    <!-- 1. End-to-End Suite (4 Scripts) -->
    <test name="End-to-End User Journeys">
        <classes>
            <class name="com.saucedemo.tests.E2ETests">
                <methods>
                    <include name="testStandardUserLogin"/>
                    <include name="testProblemUserLogin"/>
                    <include name="testPerformanceUserLogin"/>
                    <include name="testCartPersistenceAfterLogout"/>
                </methods>
            </class>
        </classes>
    </test>

    <!-- 2. Regression Suite (12 Scripts via DataProviders) -->
    <test name="Regression and Validation Suite">
        <classes>
            <class name="com.saucedemo.tests.RegressionTests">
                <methods>
                    <include name="testLoginValidation"/>   <!-- 5 Scenarios -->
                    <include name="testCheckoutFields"/>    <!-- 3 Scenarios -->
                    <include name="testProductSorting"/>    <!-- 4 Scenarios -->
                </methods>
            </class>
        </classes>
    </test>

</suite>